# Copy this file to .env and fill in your values
# Get these from the Discord Developer Portal: https://discord.com/developers/applications

DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional: Channel ID for daily Word of the Day auto-post (right-click channel → Copy ID)
WORT_CHANNEL_ID=your_channel_id_here
